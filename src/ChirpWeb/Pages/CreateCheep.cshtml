@page
@model ChirpWeb.Pages.CreateCheepModel
@{
    ViewData["Title"] = "Create Cheep";
    Layout = "_Layout";
}

<h2>Create a New Cheep</h2>

<form method="post">
    <div class = "form-group">
        <label for= "CheepText" >Your Cheep</label>
        <textarea id="CheepText" name="CheepText" asp-for="CheepText" class="from-control" required></textarea>
        <span asp-validation-for="CheepText" class="text-danger"></span>
    </div>
    <button type = "submit" class="btn btn-primary">Submit</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}